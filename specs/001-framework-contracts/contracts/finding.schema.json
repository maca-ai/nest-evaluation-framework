{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://maca-ai.github.io/nef/schemas/1.0.0/finding.schema.json",
  "title": "Finding",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "fingerprint",
    "authority",
    "source",
    "title",
    "claim",
    "severity",
    "evidence_digests",
    "first_seen_run_id",
    "last_seen_run_id"
  ],
  "properties": {
    "schema_version": { "const": "1.0.0" },
    "fingerprint": { "$ref": "#/$defs/sha256" },
    "authority": { "const": "candidate" },
    "source": { "enum": ["deterministic", "model-supported", "model-suspected"] },
    "title": { "type": "string", "minLength": 1 },
    "claim": { "type": "string", "minLength": 1 },
    "severity": { "enum": ["critical", "high", "medium", "low", "informational"] },
    "evidence_digests": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": { "$ref": "#/$defs/sha256" }
    },
    "first_seen_run_id": { "type": "string", "minLength": 1 },
    "last_seen_run_id": { "type": "string", "minLength": 1 }
  },
  "$defs": {
    "sha256": { "type": "string", "pattern": "^[0-9a-f]{64}$" }
  }
}
