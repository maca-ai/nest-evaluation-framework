{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://maca-ai.github.io/nef/schemas/1.0.0/disposition.schema.json",
  "title": "Disposition",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "finding_fingerprint",
    "decision",
    "actor",
    "decided_at",
    "rationale",
    "evidence_digests",
    "run_ids"
  ],
  "properties": {
    "schema_version": { "const": "1.0.0" },
    "finding_fingerprint": { "$ref": "#/$defs/sha256" },
    "decision": { "enum": ["confirmed", "rejected", "needs-more-evidence", "accepted-risk", "fixed"] },
    "actor": { "type": "string", "minLength": 1 },
    "decided_at": { "type": "string", "format": "date-time" },
    "rationale": { "type": "string", "minLength": 1 },
    "evidence_digests": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": { "$ref": "#/$defs/sha256" }
    },
    "run_ids": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": { "type": "string", "minLength": 1 }
    }
  },
  "$defs": {
    "sha256": { "type": "string", "pattern": "^[0-9a-f]{64}$" }
  }
}
