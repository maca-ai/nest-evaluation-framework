{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://maca-ai.github.io/nef/schemas/1.0.0/campaign-request.schema.json",
  "title": "CampaignRequest",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "run_id",
    "scheduled_date",
    "attempt",
    "campaign_id",
    "target_snapshot_manifest",
    "target_snapshot_manifest_digest",
    "target_capability_manifest",
    "target_capability_manifest_digest",
    "campaign_configuration_digest",
    "budgets",
    "disposable_workspace",
    "randomness"
  ],
  "properties": {
    "schema_version": { "const": "1.0.0" },
    "run_id": { "type": "string", "minLength": 1 },
    "scheduled_date": { "type": "string", "format": "date" },
    "attempt": { "type": "integer", "minimum": 1 },
    "campaign_id": { "$ref": "#/$defs/stableId" },
    "target_snapshot_manifest": { "$ref": "target-snapshot-manifest.schema.json" },
    "target_snapshot_manifest_digest": { "$ref": "#/$defs/sha256" },
    "target_capability_manifest": { "$ref": "target-capability-manifest.schema.json" },
    "target_capability_manifest_digest": { "$ref": "#/$defs/sha256" },
    "campaign_configuration_digest": { "$ref": "#/$defs/sha256" },
    "budgets": {
      "type": "object",
      "additionalProperties": false,
      "required": ["timeout_seconds", "max_cost_eur", "max_memory_mib", "max_output_bytes"],
      "properties": {
        "timeout_seconds": { "type": "integer", "minimum": 1 },
        "max_cost_eur": { "$ref": "#/$defs/decimal" },
        "max_memory_mib": { "type": "integer", "minimum": 1 },
        "max_output_bytes": { "type": "integer", "minimum": 1 }
      }
    },
    "disposable_workspace": { "type": "string", "pattern": "^\\.targets/nest/[0-9a-f]{40}(?:/(?!\\.{1,2}(?:/|$))[^/]+)*$" },
    "randomness": {
      "type": "object",
      "additionalProperties": false,
      "required": ["mode"],
      "properties": {
        "mode": { "enum": ["not-applicable", "recorded"] },
        "seed": { "type": ["integer", "null"] },
        "supplemental_reproduction_data": { "type": ["string", "null"] }
      }
    }
  },
  "$defs": {
    "sha256": { "type": "string", "pattern": "^[0-9a-f]{64}$" },
    "decimal": { "type": "string", "pattern": "^-?(0|[1-9][0-9]*)(\\.[0-9]+)?$" },
    "stableId": { "type": "string", "pattern": "^[a-z0-9]+(?:[/-][a-z0-9]+)*$" }
  }
}
