{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://maca-ai.github.io/nef/schemas/1.0.0/target-capability-manifest.schema.json",
  "title": "TargetCapabilityManifest",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "target_sha",
    "protocol_digest",
    "capabilities",
    "required_campaigns",
    "unavailable_campaigns_with_reasons",
    "observed_at"
  ],
  "properties": {
    "schema_version": { "const": "1.0.0" },
    "target_sha": { "$ref": "#/$defs/sha1" },
    "protocol_digest": { "$ref": "#/$defs/sha256" },
    "capabilities": {
      "type": "array",
      "items": { "$ref": "#/$defs/capability" },
      "minItems": 1
    },
    "required_campaigns": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": { "$ref": "#/$defs/stableId" }
    },
    "unavailable_campaigns_with_reasons": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["campaign_id", "state", "reason", "missing_evidence"],
        "properties": {
          "campaign_id": { "$ref": "#/$defs/stableId" },
          "state": { "const": "skipped" },
          "reason": { "type": "string", "minLength": 1 },
          "missing_evidence": {
            "type": "array",
            "minItems": 1,
            "uniqueItems": true,
            "items": { "type": "string", "minLength": 1 }
          }
        }
      }
    },
    "observed_at": { "type": "string", "format": "date-time" }
  },
  "$defs": {
    "sha1": { "type": "string", "pattern": "^[0-9a-f]{40}$" },
    "sha256": { "type": "string", "pattern": "^[0-9a-f]{64}$" },
    "stableId": { "type": "string", "pattern": "^[a-z0-9]+(?:[/-][a-z0-9]+)*$" },
    "capability": {
      "type": "object",
      "additionalProperties": false,
      "required": ["capability_id", "state", "evidence"],
      "properties": {
        "capability_id": { "$ref": "#/$defs/stableId" },
        "state": { "enum": ["available", "unavailable"] },
        "evidence": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": { "type": "string", "minLength": 1 }
        },
        "reason": { "type": ["string", "null"], "minLength": 1 }
      },
      "allOf": [
        {
          "if": { "properties": { "state": { "const": "unavailable" } }, "required": ["state"] },
          "then": {
            "required": ["reason"],
            "properties": { "reason": { "type": "string", "minLength": 1 } }
          }
        }
      ]
    }
  }
}
