{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://maca-ai.github.io/nef/schemas/1.0.0/target-snapshot-manifest.schema.json",
  "title": "TargetSnapshotManifest",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "repository_url",
    "requested_ref",
    "resolved_sha",
    "branch_or_tag",
    "dirty",
    "nef_sha",
    "lock_digest",
    "constitution_version",
    "constitution_digest",
    "relevant_source_digests",
    "environment_fingerprint",
    "consulted_paths",
    "observed_at"
  ],
  "properties": {
    "schema_version": { "const": "1.0.0" },
    "repository_url": { "type": "string", "format": "uri", "minLength": 1, "pattern": "^(?![^:]+://[^/@]+@).+$" },
    "requested_ref": { "type": "string", "minLength": 1 },
    "resolved_sha": { "$ref": "#/$defs/sha1" },
    "branch_or_tag": { "type": "string", "minLength": 1 },
    "dirty": { "type": "boolean" },
    "nef_sha": {
      "oneOf": [
        { "$ref": "#/$defs/sha1" },
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["unavailable_reason"],
          "properties": {
            "unavailable_reason": { "type": "string", "minLength": 1 }
          }
        }
      ]
    },
    "lock_digest": { "$ref": "#/$defs/sha256" },
    "constitution_version": { "$ref": "#/$defs/semver" },
    "constitution_digest": { "$ref": "#/$defs/sha256" },
    "relevant_source_digests": {
      "type": "object",
      "minProperties": 1,
      "additionalProperties": { "$ref": "#/$defs/sha256" },
      "propertyNames": { "type": "string", "minLength": 1 }
    },
    "environment_fingerprint": {
      "type": "object",
      "additionalProperties": false,
      "required": ["digest", "runner", "operating_system", "architecture", "locale", "timezone"],
      "properties": {
        "digest": { "$ref": "#/$defs/sha256" },
        "runner": { "type": "string", "minLength": 1 },
        "operating_system": { "type": "string", "minLength": 1 },
        "architecture": { "type": "string", "minLength": 1 },
        "locale": { "type": "string", "minLength": 1 },
        "timezone": { "type": "string", "minLength": 1 },
        "tool_versions": {
          "type": "object",
          "additionalProperties": { "type": "string", "minLength": 1 }
        }
      }
    },
    "consulted_paths": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": { "type": "string", "minLength": 1 }
    },
    "observed_at": { "type": "string", "format": "date-time" }
  },
  "$defs": {
    "sha1": { "type": "string", "pattern": "^[0-9a-f]{40}$" },
    "sha256": { "type": "string", "pattern": "^[0-9a-f]{64}$" },
    "semver": { "type": "string", "pattern": "^(0|[1-9][0-9]*)\\.(0|[1-9][0-9]*)\\.(0|[1-9][0-9]*)$" }
  }
}
